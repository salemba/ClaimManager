# .gitignore for ClaimManager (dotnet + Node + frontend)

# Build outputs
bin/
obj/

# User-specific files
*.user
*.suo
*.userosscache
*.sln.docstates

# VS Code
.vscode/

# Node modules
node_modules/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment
.env
.env.*

# OS generated files
.DS_Store
Thumbs.db

# Test coverage
coverage/

# Python virtual environments
.venv/
venv/

# Others
*.swp
*.tmp

# Ignore local packages lock files (optional)
package-lock.json
yarn.lock
pnpm-lock.yaml

# Ignore output folders
/dist
/build

# Ignore IDE folders
.idea/

# Ignore bmad output
_bmad-output/

# Ignore .agents
.agents/
